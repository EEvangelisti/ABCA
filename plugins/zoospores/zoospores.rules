# Zoospore agent-based swimming models.
#
# INIT can be FULL, DISK, or RING.
# AGENTS can be overridden from the CLI with --agents.

AUTOMATON "ZOOSPORE CALIBRATED": DIRS=360/BASE_STEP=1/FAST_STEP=2/FAST_PROB=0.55/WIGGLE=11/PERSISTENCE=48/MIN_TURN=30/MAX_AGE=8/AGENTS=200/INIT=DISK/RADIUS=100/THICKNESS=4
